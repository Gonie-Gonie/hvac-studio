{
  "id": "ml_inference",
  "name": "ML Inference Component",
  "kind": "user_python",
  "category": "physical_component",
  "execution_mode": "step",
  "class_name": "MLInferenceComponent",
  "source": {
    "layout": "generated_wrapper",
    "metadata": "component.json",
    "init": "user_init.py",
    "step": "user_step.py",
    "helpers": "helpers.py",
    "wrapper": "wrapper.py"
  },
  "assets": [
    "model.json",
    "feature_schema.json",
    "target_schema.json",
    "validation_report.json"
  ],
  "inputs": [
    {
      "id": "features",
      "name": "Features",
      "preset": "scalar_input",
      "medium": "signal",
      "value_type": "object",
      "required": true
    }
  ],
  "outputs": [
    {
      "id": "supply_air_temperature_c",
      "name": "Supply Air Temperature",
      "preset": "air_outlet",
      "medium": "air",
      "value_type": "float",
      "unit": "degC"
    },
    {
      "id": "cooling_power_kw",
      "name": "Cooling Power",
      "preset": "electric_power_output",
      "medium": "electricity",
      "value_type": "float",
      "unit": "kW"
    }
  ],
  "parameters": {
    "output_bias": 0.0
  },
  "parameter_defs": {
    "output_bias": {
      "display_name": "Output Bias",
      "unit": "native",
      "default": 0.0,
      "current": 0.0,
      "bounds": {
        "min": -10.0,
        "max": 10.0
      },
      "role": "calibration_target",
      "group": "ML",
      "description": "Bias added to each model output after inference."
    }
  },
  "state_defs": {
    "model": {
      "display_name": "Loaded Model",
      "description": "JSON model loaded once during initialize."
    }
  },
  "ml_metadata": {
    "model_format": "custom",
    "model_file": "model.json",
    "feature_schema_file": "feature_schema.json",
    "target_schema_file": "target_schema.json",
    "validation_report_file": "validation_report.json",
    "required_packages": [],
    "valid_time_resolution": "step",
    "valid_input_ranges": {
      "outdoor_temperature_c": {
        "min": -20.0,
        "max": 45.0
      },
      "return_air_temperature_c": {
        "min": 10.0,
        "max": 35.0
      },
      "chw_setpoint_c": {
        "min": 4.0,
        "max": 12.0
      },
      "fan_speed_fraction": {
        "min": 0.0,
        "max": 1.0
      }
    }
  }
}
