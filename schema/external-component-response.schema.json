{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hvac-studio.local/schema/external-component-response.schema.json",
  "title": "HVAC Studio External Component Response",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "outputs": {
      "type": "object"
    },
    "state": {
      "type": "object"
    },
    "logs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/log"
      }
    },
    "error": {
      "$ref": "#/$defs/error"
    }
  },
  "$defs": {
    "log": {
      "type": "object",
      "required": ["message"],
      "additionalProperties": false,
      "properties": {
        "component": {
          "type": "string"
        },
        "stage": {
          "type": "string"
        },
        "stream": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "message": {
          "type": "string"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
