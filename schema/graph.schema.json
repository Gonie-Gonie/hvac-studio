{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hvac-studio.local/schema/graph.schema.json",
  "title": "HVAC Studio Graph",
  "type": "object",
  "required": ["schema_version", "systems", "components", "connections"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.1\\.[0-9]+$",
      "description": "Graph artifact schema version. The current alpha compatibility line is 0.1.x."
    },
    "systems": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/system"
      }
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/connection"
      }
    }
  },
  "$defs": {
    "system": {
      "type": "object",
      "required": ["id", "components", "connections", "public_inputs", "public_outputs"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "components": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "connections": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "public_inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicNode"
          }
        },
        "public_outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicNode"
          }
        }
      }
    },
    "publicNode": {
      "type": "object",
      "required": ["id", "component", "node"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "component": {
          "type": "string",
          "minLength": 1
        },
        "node": {
          "type": "string",
          "minLength": 1
        },
        "medium": {
          "type": "string"
        },
        "value_type": {
          "type": "string"
        },
        "unit": {
          "type": ["string", "null"]
        },
        "required": {
          "type": "boolean"
        },
        "default": true
      }
    },
    "component": {
      "type": "object",
      "required": ["id", "kind", "nodes"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["user_python", "external_exe", "composite"]
        },
        "category": {
          "type": "string",
          "enum": ["physical_component", "controller", "data_source", "data_sink", "utility", "solver", "composite_wrapper"]
        },
        "execution_mode": {
          "type": "string",
          "enum": ["step", "vectorized", "initialization_only", "external_executable"]
        },
        "class": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/componentSource"
        },
        "nodes": {
          "type": "object",
          "required": ["inputs", "outputs"],
          "additionalProperties": false,
          "properties": {
            "inputs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/node"
              }
            },
            "outputs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/node"
              }
            }
          }
        },
        "parameters": {
          "type": "object"
        },
        "parameter_defs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/parameterDefinition"
          }
        },
        "state_defs": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/stateDefinition"
          }
        },
        "solver_boundary": {
          "$ref": "#/$defs/solverBoundary"
        },
        "ml_metadata": {
          "$ref": "#/$defs/mlMetadata"
        },
        "composite": {
          "$ref": "#/$defs/compositeReference"
        }
      }
    },
    "componentSource": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "layout": {
          "type": "string",
          "enum": ["single_file_class", "generated_wrapper"]
        },
        "metadata": {
          "type": "string"
        },
        "init": {
          "type": "string"
        },
        "step": {
          "type": "string"
        },
        "helpers": {
          "type": "string"
        },
        "wrapper": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "layout": {
                "const": "generated_wrapper"
              }
            },
            "required": ["layout"]
          },
          "then": {
            "required": ["step", "wrapper"]
          }
        }
      ]
    },
    "parameterDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "display_name": {
          "type": "string"
        },
        "unit": {
          "type": ["string", "null"]
        },
        "default": true,
        "current": true,
        "bounds": {
          "$ref": "#/$defs/valueBounds"
        },
        "role": {
          "type": "string",
          "enum": ["fixed", "scenario_input", "calibration_target", "optimization_variable", "derived"]
        },
        "group": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "visible": {
          "type": "boolean"
        }
      }
    },
    "stateDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "display_name": {
          "type": "string"
        },
        "unit": {
          "type": ["string", "null"]
        },
        "initial": true,
        "description": {
          "type": "string"
        }
      }
    },
    "solverBoundary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string"
        },
        "max_iterations": {
          "type": "integer",
          "minimum": 1
        },
        "tolerance": {
          "type": "number",
          "minimum": 0
        },
        "description": {
          "type": "string"
        }
      }
    },
    "mlMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_format": {
          "type": "string",
          "enum": ["pickle", "joblib", "onnx", "torch", "tensorflow", "custom"]
        },
        "model_file": {
          "type": "string"
        },
        "input_scaler_file": {
          "type": "string"
        },
        "output_scaler_file": {
          "type": "string"
        },
        "feature_schema_file": {
          "type": "string"
        },
        "target_schema_file": {
          "type": "string"
        },
        "training_metadata_file": {
          "type": "string"
        },
        "validation_report_file": {
          "type": "string"
        },
        "required_packages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "valid_time_resolution": {
          "type": "string"
        },
        "valid_input_ranges": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/valueBounds"
          }
        }
      }
    },
    "compositeReference": {
      "type": "object",
      "required": ["system"],
      "additionalProperties": false,
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "valueBounds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min": true,
        "max": true
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "medium", "value_type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "preset": {
          "type": "string",
          "enum": ["water_inlet", "water_outlet", "air_inlet", "air_outlet", "control_signal_input", "electric_power_output", "scalar_input", "scalar_output", "time_series_input"]
        },
        "direction": {
          "type": "string",
          "enum": ["inlet", "outlet", "bidirectional", "signal"]
        },
        "medium": {
          "type": "string"
        },
        "value_type": {
          "type": "string"
        },
        "unit": {
          "type": ["string", "null"]
        },
        "required": {
          "type": "boolean"
        },
        "default": true
      }
    },
    "connection": {
      "type": "object",
      "required": ["id", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "$ref": "#/$defs/endpoint"
        },
        "to": {
          "$ref": "#/$defs/endpoint"
        },
        "allow_medium_mismatch": {
          "type": "boolean"
        },
        "medium_override_reason": {
          "type": "string"
        },
        "unit_conversion": {
          "$ref": "#/$defs/unitConversion"
        }
      }
    },
    "unitConversion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["linear"]
        },
        "factor": {
          "type": "number"
        },
        "offset": {
          "type": "number"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["component", "node"],
      "additionalProperties": false,
      "properties": {
        "component": {
          "type": "string",
          "minLength": 1
        },
        "node": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
