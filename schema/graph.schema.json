{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hvac-studio.local/schema/graph.schema.json",
  "title": "HVAC Studio Graph",
  "type": "object",
  "required": ["schema_version", "systems", "components", "connections"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "systems": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/system"
      }
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "connections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/connection"
      }
    }
  },
  "$defs": {
    "system": {
      "type": "object",
      "required": ["id", "components", "connections", "public_inputs", "public_outputs"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "components": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "connections": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "public_inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicNode"
          }
        },
        "public_outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/publicNode"
          }
        }
      }
    },
    "publicNode": {
      "type": "object",
      "required": ["id", "component", "node"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "component": {
          "type": "string",
          "minLength": 1
        },
        "node": {
          "type": "string",
          "minLength": 1
        },
        "medium": {
          "type": "string"
        },
        "value_type": {
          "type": "string"
        },
        "unit": {
          "type": ["string", "null"]
        },
        "required": {
          "type": "boolean"
        },
        "default": true
      }
    },
    "component": {
      "type": "object",
      "required": ["id", "kind", "nodes"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["user_python", "builtin_go", "external_exe", "future_compiled"]
        },
        "class": {
          "type": "string"
        },
        "nodes": {
          "type": "object",
          "required": ["inputs", "outputs"],
          "additionalProperties": false,
          "properties": {
            "inputs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/node"
              }
            },
            "outputs": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/node"
              }
            }
          }
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "medium", "value_type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string"
        },
        "direction": {
          "type": "string",
          "enum": ["inlet", "outlet", "bidirectional", "signal"]
        },
        "medium": {
          "type": "string"
        },
        "value_type": {
          "type": "string"
        },
        "unit": {
          "type": ["string", "null"]
        },
        "required": {
          "type": "boolean"
        },
        "default": true
      }
    },
    "connection": {
      "type": "object",
      "required": ["id", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "$ref": "#/$defs/endpoint"
        },
        "to": {
          "$ref": "#/$defs/endpoint"
        }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["component", "node"],
      "additionalProperties": false,
      "properties": {
        "component": {
          "type": "string",
          "minLength": 1
        },
        "node": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

